# Looms Development Environment
# Used with: docker compose --profile dev up

# App
LOOMS_PORT=5175
REALTIME_PORT=5199
LOG_LEVEL=debug

# Dolt (containerized, isolated from host)
DOLT_DATABASE=beads_looms
DOLT_USER=root
DOLT_PASSWORD=
DOLT_DEV_PORT=13307

# Penpot (if running alongside)
PENPOT_SECRET_KEY=dev-only-insecure-key
PENPOT_DB_PASSWORD=penpot
