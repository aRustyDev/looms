# Looms Test/Staging Environment
# Used with: docker compose --profile test up
#
# Connects to EXTERNAL Dolt — set DOLT_HOST and DOLT_PORT to your
# production (or staging) database. No Dolt container is started.

# App
LOOMS_PORT=5176
REALTIME_PORT=5199
LOG_LEVEL=info

# Dolt (external — REQUIRED, compose will error if unset)
DOLT_HOST=127.0.0.1
DOLT_PORT=13306
DOLT_DATABASE=beads_looms
DOLT_USER=root
DOLT_PASSWORD=
